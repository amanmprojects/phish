# Copy to .env and fill in values:
#   cp .env.example .env   (or copy on Windows)

# Optional: Tavily for Deep Investigate web_search / web_fetch
TAVILY_API_KEY=

# Optional: force Pi model (otherwise uses ~/.pi agent defaults / SuperGrok)
# PI_PROVIDER=supergrok
# PI_MODEL=grok-4.5

# Server bind
# HOST=127.0.0.1
# PORT=8787
# WEB_PORT=5173

# LAN demo: bind all interfaces + open CORS
# HOST=0.0.0.0
# CORS_OPEN=1

# Or restrict CORS when public-bound (comma-separated origins)
# CORS_ORIGINS=http://192.168.1.10:5173,http://localhost:5173
