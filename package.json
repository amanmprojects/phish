{
  "name": "phish",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phish — AI phishing detector",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "dev:all": "concurrently -k -n server,web -c blue,green npm:dev:server npm:dev:web",
    "dev:public": "node scripts/run-public.mjs",
    "build": "vite build --config web/vite.config.ts",
    "start": "tsx server/index.ts",
    "start:prod": "npm run build && npm start",
    "start:public": "node scripts/start-public.mjs",
    "cli": "tsx server/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test server/**/*.test.ts web/src/**/*.test.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@hono/node-server": "^1.14.1",
    "dotenv": "^16.5.0",
    "hono": "^4.7.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "esbuild@0.25.12": true
  }
}
